{
  "cases": [
    {
      "name": "valid_credential_verified",
      "description": "Server verification accepts a credential echo that matches the route and has a future expires value.",
      "input": {
        "realm": "api.example.com",
        "secretKey": "secret-key",
        "method": "tempo",
        "intent": "charge",
        "request": {
          "amount": "100",
          "currency": "0xabc",
          "recipient": "0xdef"
        },
        "expires": "2099-01-01T00:00:00Z",
        "credential": {
          "challenge": {
            "id": "Ip25HCkqcMaW6FT_ziOG9BT58-7_KEwkzhdUwX8tmI8",
            "realm": "api.example.com",
            "method": "tempo",
            "intent": "charge",
            "request": {
              "amount": "100",
              "currency": "0xabc",
              "recipient": "0xdef"
            },
            "expires": "2099-01-01T00:00:00Z"
          },
          "payload": {
            "type": "hash",
            "hash": "0xabc123"
          }
        }
      },
      "expected": {
        "ok": true,
        "receipt": {
          "status": "success",
          "timestamp": "2026-01-29T12:00:00Z",
          "reference": "conformance-receipt",
          "method": "tempo"
        }
      }
    },
    {
      "name": "missing_credential_expires_rejected_with_route_expiry",
