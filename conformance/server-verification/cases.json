          "recipient": "0xdef"
        },
        "expires": "2099-01-01T00:00:00Z",
        "credential": {
          "challenge": {
            "id": "73URalxGl0MMCrlT4Yx32M5SQduyaDXWvs2rINyPPFA",
            "realm": "api.example.com",
            "method": "tempo",
            "intent": "charge",
            "request": {
              "amount": "100",
              "currency": "0xabc",
              "recipient": "0xdef"
            }
          },
          "payload": {
            "type": "hash",
            "hash": "0xabc123"
          }
        }
      },
      "expected": {
        "ok": false,
