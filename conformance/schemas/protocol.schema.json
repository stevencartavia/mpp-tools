{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.xyz/mpp-tools/conformance/schemas/protocol.schema.json",
  "title": "MPP Conformance Protocol Values",
  "$defs": {
    "Operation": {
      "type": "string",
      "enum": [
        "challenge.parse",
        "challenge.format",
        "credential.parse",
        "credential.format",
        "receipt.parse",
        "receipt.format",
        "base64url.encode",
        "base64url.decode",
        "challenge.id",
        "server.verify",
        "tempo.fee_payer.cosign",
        "tempo.receipt.verify",
        "http.payment_request",
        "stripe.external_id_binding"
      ]
    },
    "ErrorType": {
      "type": "string",
      "enum": [
        "parse_error",
        "format_error",
        "encoding_error",
        "generation_error",
        "verification_error",
        "http_error",
        "unsupported_operation",
        "unknown_error"
      ]
    },
    "JsonObject": {
      "type": "object",
      "additionalProperties": true
    },
    "Challenge": {
      "type": "object",
      "required": ["id", "realm", "method", "intent", "request"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "realm": { "type": "string" },
        "method": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "minLength": 1 },
        "request": { "$ref": "#/$defs/JsonObject" },
        "expires": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "digest": { "type": "string" },
        "opaque": { "type": "string" }
      }
    },
    "Credential": {
      "type": "object",
      "required": ["challenge", "payload"],
      "additionalProperties": false,
      "properties": {
        "challenge": { "$ref": "#/$defs/Challenge" },
        "payload": { "$ref": "#/$defs/JsonObject" },
        "source": {
          "anyOf": [
            { "$ref": "#/$defs/JsonObject" },
            { "type": "string" },
            { "type": "null" }
          ]
        }
      }
    },
    "Receipt": {
      "type": "object",
      "required": ["status", "timestamp", "reference"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "method": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "reference": { "type": "string", "minLength": 1 },
        "externalId": { "type": "string" },
        "extra": { "$ref": "#/$defs/JsonObject" }
      }
    },
    "HeaderInput": {
      "type": "object",
      "required": ["header"],
      "additionalProperties": false,
      "properties": {
        "header": { "type": "string" }
      }
    },
    "HeaderOutput": {
      "type": "object",
      "required": ["header"],
      "additionalProperties": false,
      "properties": {
        "header": { "type": "string" }
      }
    },
    "TextValue": {
      "type": "object",
      "required": ["text"],
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" }
      }
    },
    "ChallengeIdInput": {
      "type": "object",
      "required": ["secretKey", "realm", "method", "intent", "request"],
      "additionalProperties": false,
      "properties": {
        "secretKey": { "type": "string", "minLength": 1 },
        "realm": { "type": "string" },
        "method": { "type": "string" },
        "intent": { "type": "string" },
        "request": { "$ref": "#/$defs/JsonObject" },
        "expires": { "type": "string" },
        "description": { "type": "string" },
        "digest": { "type": "string" },
        "opaque": { "type": "string" }
      }
    },
    "ChallengeIdOutput": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "StripeExternalIdBindingInput": {
      "type": "object",
      "required": ["request", "payload", "paymentIntent"],
      "additionalProperties": false,
      "properties": {
        "request": { "$ref": "#/$defs/JsonObject" },
        "payload": { "$ref": "#/$defs/JsonObject" },
        "paymentIntent": {
          "type": "object",
          "required": ["id", "status"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "status": { "type": "string", "minLength": 1 },
            "replayed": { "type": "boolean" }
          }
        }
      }
    },
    "StripeExternalIdBindingResult": {
      "oneOf": [
        {
          "type": "object",
          "required": ["ok", "receipt"],
          "additionalProperties": false,
          "properties": {
            "ok": { "const": true },
            "receipt": { "$ref": "#/$defs/Receipt" }
          }
        },
        {
          "type": "object",
          "required": ["ok", "errorType"],
          "additionalProperties": false,
          "properties": {
            "ok": { "const": false },
            "errorType": { "enum": ["invalid_challenge", "verification_failed"] }
          }
        }
      ]
    },
    "HttpPaymentMode": {
      "type": "string",
      "enum": [
        "payment",
        "plain",
        "invalid_payload",
        "mismatched_request",
        "invalid_challenge_id"
      ]
    },
    "HttpPaymentRequest": {
      "type": "object",
      "required": ["url", "method", "headers", "body", "payment", "mode"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "body": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "payment": {
          "type": "object",
          "required": ["payload"],
          "additionalProperties": false,
          "properties": {
            "payload": { "$ref": "#/$defs/JsonObject" },
            "source": {
              "anyOf": [
                { "$ref": "#/$defs/JsonObject" },
                { "type": "string" },
                { "type": "null" }
              ]
            }
          }
        },
        "mode": { "$ref": "#/$defs/HttpPaymentMode" }
      }
    },
    "HttpResponse": {
      "type": "object",
      "required": ["status", "headers", "body"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "body": { "type": "string" }
      }
    },
    "ServerVerifyRequest": {
      "type": "object",
      "required": ["realm", "secretKey", "method", "intent", "request", "credential"],
      "additionalProperties": false,
      "properties": {
        "realm": { "type": "string" },
        "secretKey": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "minLength": 1 },
        "request": { "$ref": "#/$defs/JsonObject" },
        "expires": { "type": "string" },
        "verificationError": { "type": "string" },
        "credential": { "$ref": "#/$defs/Credential" }
      }
    },
    "ServerVerifyResult": {
      "type": "object",
      "required": ["ok"],
      "additionalProperties": false,
      "properties": {
        "ok": { "type": "boolean" },
        "errorType": {
          "type": "string",
          "enum": [
            "malformed_credential",
            "invalid_challenge",
            "payment_expired",
            "verification_failed",
            "unknown_error"
          ]
        },
        "receipt": { "$ref": "#/$defs/Receipt" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "ok": { "const": true } },
            "required": ["ok"]
          },
          "then": {
            "required": ["receipt"],
            "not": { "required": ["errorType"] }
          }
        },
        {
          "if": {
            "properties": { "ok": { "const": false } },
            "required": ["ok"]
          },
          "then": {
            "required": ["errorType"],
            "not": { "required": ["receipt"] }
          }
        }
      ]
    },
    "HexValue": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]*$"
    },
    "UintValue": {
      "anyOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "string", "pattern": "^(0|[1-9][0-9]*|max|now\\+[1-9][0-9]*)$" }
      ]
    },
    "TempoFeePayerCall": {
      "type": "object",
      "required": ["to", "value", "data"],
      "additionalProperties": false,
      "properties": {
        "to": { "$ref": "#/$defs/HexValue" },
        "value": { "$ref": "#/$defs/UintValue" },
        "data": { "$ref": "#/$defs/HexValue" }
      }
    },
    "TempoFeePayerTransaction": {
      "type": "object",
      "required": [
        "chainId",
        "maxPriorityFeePerGas",
        "maxFeePerGas",
        "gasLimit",
        "calls",
        "accessList",
        "nonceKey",
        "nonce",
        "validBefore",
        "feeToken"
      ],
      "additionalProperties": false,
      "properties": {
        "chainId": { "$ref": "#/$defs/UintValue" },
        "maxPriorityFeePerGas": { "$ref": "#/$defs/UintValue" },
        "maxFeePerGas": { "$ref": "#/$defs/UintValue" },
        "gasLimit": { "$ref": "#/$defs/UintValue" },
        "calls": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/TempoFeePayerCall" }
        },
        "accessList": {
          "type": "array",
          "items": true
        },
        "nonceKey": { "$ref": "#/$defs/UintValue" },
        "nonce": { "$ref": "#/$defs/UintValue" },
        "validBefore": { "$ref": "#/$defs/UintValue" },
        "feeToken": {
          "anyOf": [
            { "$ref": "#/$defs/HexValue" },
            { "type": "null" }
          ]
        }
      }
    },
    "TempoFeePayerCosignInput": {
      "type": "object",
      "required": ["payerPrivateKey", "feePayerPrivateKey", "feeToken", "request", "transaction"],
      "additionalProperties": false,
      "properties": {
        "payerPrivateKey": { "$ref": "#/$defs/HexValue" },
        "feePayerPrivateKey": { "$ref": "#/$defs/HexValue" },
        "feeToken": { "$ref": "#/$defs/HexValue" },
        "challenge": { "$ref": "#/$defs/Challenge" },
        "request": { "$ref": "#/$defs/JsonObject" },
        "transaction": { "$ref": "#/$defs/TempoFeePayerTransaction" }
      }
    },
    "TempoFeePayerCosignOutput": {
      "type": "object",
      "required": ["type", "feeToken", "feePayerSignaturePresent", "accessListLength", "callCount"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "0x76" },
        "feeToken": { "$ref": "#/$defs/HexValue" },
        "feePayerSignaturePresent": { "type": "boolean" },
        "accessListLength": { "type": "integer", "minimum": 0 },
        "callCount": { "type": "integer", "minimum": 0 }
      }
    },
    "TempoReceiptVerificationInput": {
      "type": "object",
      "required": ["credential", "receipt"],
      "additionalProperties": false,
      "properties": {
        "credential": { "$ref": "#/$defs/Credential" },
        "receipt": { "$ref": "#/$defs/JsonObject" }
      }
    },
    "TempoReceiptVerificationOutput": {
      "type": "object",
      "required": ["status", "reference"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "const": "success" },
        "reference": { "type": "string", "minLength": 1 }
      }
    }
  }
}
