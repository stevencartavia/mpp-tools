{
  "$schema": "../../schemas/adapter-manifest.schema.json",
  "schema": 1,
  "name": "rust",
  "language": "rust",
  "command": [
    "./target/release/adapter"
  ],
  "build": [
    "cargo",
    "build",
    "--release",
    "--quiet"
  ],
  "cwd": ".",
  "capabilities": [
    "challenge.parse",
    "challenge.format",
    "credential.parse",
    "credential.format",
    "receipt.parse",
    "receipt.format",
    "base64url.encode",
    "base64url.decode",
    "challenge.id"
  ]
}
