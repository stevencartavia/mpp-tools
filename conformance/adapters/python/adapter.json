{
  "$schema": "../../schemas/adapter-manifest.schema.json",
  "schema": 1,
  "name": "python",
  "language": "python",
  "command": [
    "uv",
    "run",
    "--project",
    ".",
    "--python",
    "3.12",
    "adapter.py"
  ],
  "cwd": ".",
  "capabilities": [
    "challenge.parse",
    "challenge.format",
    "credential.parse",
    "credential.format",
    "receipt.parse",
    "receipt.format",
    "base64url.encode",
    "base64url.decode",
    "challenge.id",
    "tempo.receipt.verify"
  ]
}
