    {
      "name": "cross_origin_redirect_before_402_rejected",
      "path": "/charge/redirect-cross-origin",
      "client_flow": true,
      "expect_no_authorization": true,
      "expect_error_type": "http_error",
      "expect_error_message_contains": "Refusing to send payment credential across redirect",
      "redirect_to": "/charge/redirect-cross-origin-target",
      "redirect_to_port_offset": 1,
      "payload": {
        "type": "transaction",
        "signature": "0xredirect"
      }
    },
