{
  "version": "1.0.0",
  "cases": [
    {
      "name": "success_charge",
      "path": "/charge/success",
      "request": {
        "amount": "1000",
        "currency": "USD",
        "recipient": "merchant",
        "expires": "2099-01-01T00:00:00Z"
      },
      "payload": {
        "type": "transaction",
        "signature": "0xabc123"
      },
      "expected_signature": "0xabc123",
      "receipt": {
        "status": "success",
        "reference": "ref-success"
      }
    },
    {
      "name": "verification_error",
      "path": "/charge/error",
      "request": {
        "amount": "999",
        "currency": "USD",
        "recipient": "merchant",
        "expires": "2099-01-01T00:00:00Z"
      },
      "payload": {
        "type": "transaction",
        "signature": "0xfeedface"
      },
      "expected_signature": "0xfeedface",
      "fail_verification": true
    },
